# Database
DATABASE_PRIMARY_POOLER_URL=

# Supabase (for storage and auth)
SUPABASE_URL=
# OR
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Redis Queue (for BullMQ job processing)
# In production, uses Railway internal Redis (redis://...railway.internal:6379)
REDIS_QUEUE_URL=redis://localhost:6379

# Slack Integration (for Slack file processing)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_STATE_SECRET=
SLACK_OAUTH_REDIRECT_URL=http://localhost:3003/apps/slack/oauth-callback

# LLMs (for document processing)
OPENAI_API_KEY=

# Google AI (for document tag embeddings)
GOOGLE_GENERATIVE_AI_API_KEY=

# Email (Resend - for notifications)
RESEND_API_KEY=

# Banking Providers
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENVIRONMENT=sandbox
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
ENABLEBANKING_APPLICATION_ID=
ENABLE_BANKING_KEY_CONTENT=
ENABLEBANKING_REDIRECT_URL=
TELLER_CERT_BASE64=
TELLER_KEY_BASE64=

# R2 Storage (institution logos)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Logo.dev (fallback logos for institutions)
LOGO_DEV_TOKEN=

# Environment
NODE_ENV=development
WORKER_ENV=development

# Railway (set automatically in production)
# RAILWAY_ENVIRONMENT=production
# RAILWAY_REPLICA_REGION=europe-west4-drams3a

# Optional: Health check board
BOARD_USERNAME=
BOARD_PASSWORD=

# Optional: Server port
PORT=8080

# WhatsApp
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Mistral
MISTRAL_API_KEY=

# Xero
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here
XERO_OAUTH_REDIRECT_URL=http://localhost:3003/apps/xero/oauth-callback

# QuickBooks
QUICKBOOKS_CLIENT_ID=your_client_id
QUICKBOOKS_CLIENT_SECRET=your_client_secret
QUICKBOOKS_OAUTH_REDIRECT_URL=http://localhost:3003/apps/quickbooks/oauth-callback
QUICKBOOKS_ENVIRONMENT=sandbox

# Fortnox
FORTNOX_CLIENT_ID=your_client_id_here
FORTNOX_CLIENT_SECRET=your_client_secret_here
FORTNOX_OAUTH_REDIRECT_URL=http://localhost:3003/apps/fortnox/oauth-callback




# Invoice
INVOICE_JWT_SECRET=

# Exa
EXA_API_KEY=

# CompanyEnrich (customer enrichment)
COMPANY_ENRICH_API_KEY=

# Insights (set to "true" to enable weekly insight generation + emails)
INSIGHTS_ENABLED=false
