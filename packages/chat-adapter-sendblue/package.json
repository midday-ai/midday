{
  "name": "chat-adapter-sendblue",
  "version": "0.2.0",
  "description": "Sendblue (iMessage/SMS) adapter for Chat SDK",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "chat": "^4.23.0",
    "sendblue": "^3.6.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "peerDependencies": {
    "chat": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "chat": {
      "optional": false
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/midday-ai/midday.git",
    "directory": "packages/chat-adapter-sendblue"
  },
  "homepage": "https://github.com/midday-ai/midday/tree/main/packages/chat-adapter-sendblue#readme",
  "bugs": {
    "url": "https://github.com/midday-ai/midday/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "chat",
    "chat-sdk",
    "sendblue",
    "imessage",
    "sms",
    "adapter",
    "messaging",
    "bot"
  ],
  "license": "MIT"
}
