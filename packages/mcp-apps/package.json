{
  "name": "@midday/mcp-apps",
  "version": "1.0.0",
  "private": true,
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "rm -rf dist && INPUT=time-series-chart vite build && INPUT=spending-chart vite build && INPUT=balance-sheet vite build && INPUT=invoice-preview vite build",
    "test": "bun test --exit --timeout 10000",
