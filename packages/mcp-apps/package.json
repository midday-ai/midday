    "recharts": "^3.6.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.13",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.2",
